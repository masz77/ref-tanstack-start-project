# Application Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# SQLite Database Configuration
# For local development with SQLite
DATABASE_URL="./data/app.db"

# PostgreSQL Database Configuration (commented out)
# DATABASE_URL=postgres://username:password@host:port/database

# Better Auth Configuration
# Generate a secure secret key (minimum 32 characters)
BETTER_AUTH_SECRET=your_32_character_or_longer_secret_key_here
# URL where your server is running
BETTER_AUTH_URL=http://localhost:3001

# Redis Configuration
# Redis connection URL (optional - cache will be disabled if not provided)
# Examples:
# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://username:password@host:port/database
REDIS_URL=

# OpenAI Configuration
# Replace with your actual OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-placeholder-replace-with-your-actual-openai-api-key

# CORS Origins
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8080,http://localhost:8081,http://localhost:3001

# Stripe Configuration (Required for subscription features)
# Get these from your Stripe dashboard at https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here